# If you prefer the allow-list template instead of deny-list:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore

# Binaries and local build outputs
/echonetgo
/bin/
/dist/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage and profiling artifacts
*.out
coverage.*
*.coverprofile
profile.cov
*.prof
*.pprof

# Go workspace file
go.work
go.work.sum

# Dependency directories (uncomment if you vendor deps)
# vendor/

# Local env files
.env
.env.*
!.env.example

# Editor/IDE
.idea/
.vscode/

# OS files
.DS_Store
